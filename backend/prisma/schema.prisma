// 大蓝书 数据模型（MySQL + Prisma）
// 生成客户端：npx prisma generate
// 建表迁移：npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id         Int      @id @default(autoincrement())
  openId     String?  @unique @db.VarChar(64) // 鸿蒙账号ID（openId 授权登录；华为 unionID 登录用户此字段为空）
  unionID    String?  @unique @db.VarChar(64) // 华为账号 UnionID（unionID 登录；openId 用户此字段为空）
  nickname   String   @db.VarChar(32)
  avatar     String?  @db.VarChar(255)
  gender     Int?     @default(1) // 1-男 2-女
  bio        String?  @db.VarChar(120) // 个人简介（PRD P0-4）
  followTags Json?
  status     Int      @default(1) // 1-正常 0-封禁
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime? // 软删时间，置位即视为「已注销」，旧 token 失效

  posts          Post[]
  comments       Comment[]
  ups            Up[]
  bookmarks      Bookmark[]
  userFollowTags UserFollowTag[]
  searchHistories SearchHistory[]
  bindings       UserBinding[] // 账号绑定关系（虚拟关系，FK 落在 UserBinding.userId，不新增列）
}

// 帖子表
model Post {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  title          String   @db.VarChar(100)
  content        String?  @db.Text
  coverImage     String?  @db.VarChar(255)
  images         Json? // 图片URL列表，最多9张
  genre          String   @db.VarChar(20) // review | pitfall | tutorial | debate
  tags           Json // 标签列表，1~3个
  structuredData Json? // 结构化字段（体裁不同，内容不同）
  upCount        Int      @default(0)
  bookmarkCount  Int      @default(0)
  commentCount   Int      @default(0)
  status         Int      @default(0) // 0-待审核 1-已发布 2-已拒绝
  reportCount    Int      @default(0) // 被举报累计次数（达阈值自动 status=0）
  planAVotes     Int      @default(0) // 辩论方案A投票数
  planBVotes     Int      @default(0) // 辩论方案B投票数
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comments Comment[]
  ups      Up[]
  bookmarks Bookmark[]
}

// 评论表
model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int
  post        Post     @relation(fields: [postId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  parentId    Int? // 0或null表示一级评论
  content     String   @db.Text
  isFact      Int      @default(0) // 1-事实补充
  status      Int      @default(1) // 1-正常 0-隐藏(待审核) 2-已删除
  reportCount Int      @default(0) // 被举报累计次数
  upCount     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 评论顶（点赞）记录表（与 Up 同构，防重复点赞）
model CommentUp {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())
  @@unique([userId, commentId]) // 同一用户对同一评论只能顶一次
}

// 顶（点赞）记录表
model Up {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, postId]) // 同一用户对同一帖子只能顶一次
}

// 收藏（抄作业）记录表
model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

// 标签表
model Tag {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(20) // 如"数码选购"
  emoji       String?  @db.VarChar(10) // 如"📱"
  category    String?  @db.VarChar(20) // 消费决策/动手实操/个人成长/生活方式
  useCount    Int      @default(0) // 被使用次数
  followCount Int      @default(0) // 被关注（加入圈子）次数
  createdAt   DateTime @default(now())
}

// 用户关注标签（圈子加入）记录表
model UserFollowTag {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tagName   String   @db.VarChar(20)
  createdAt DateTime @default(now())

  @@unique([userId, tagName]) // 同一用户对同一标签只能关注一次
}

// 搜索历史表
model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  keyword   String   @db.VarChar(100)
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // 按用户+时间查询历史列表
  @@index([keyword, createdAt]) // 热搜词按关键词+时间聚合
}

// 账号绑定关系表（第三方/主账号绑定统一以本表为准，横向扩展友好）
model UserBinding {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String   @db.VarChar(32)   // 'harmony' | 'huawei' | 'wechat' ... 见共享知识
  externalId String   @db.VarChar(128)  // 各 provider 的外部标识：openId / unionID / openid
  boundAt    DateTime @default(now())
  isPrimary  Boolean  @default(false)   // 当前仅 harmony 主账号为 true（合成项）
  extra      Json?    // 扩展位：头像/昵称快照等，本期未用

  @@unique([userId, provider])          // (userId, provider) 唯一：同一用户同 provider 仅一条
  @@index([provider, externalId])       // 占用校验：快速查"该 externalId 是否已被他人占用"
}

// 消息通知表（评论/顶/收藏/系统消息统一落库，前端消息中心消费）
// 设计取舍：仅用标量 userId/actorId，不建 @relation（保持轻量、避免 User 反向字段与级联复杂度）；
// actor 的昵称/头像由 notificationService.listForUser 用单独查询按需补全。
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // 接收者（被通知人）
  actorId   Int?     // 触发者（系统消息为 null）
  type      String   @db.VarChar(20)   // 'comment' | 'up' | 'bookmark' | 'follow' | 'system'
  postId    Int?     // 关联帖子（系统消息为 null）
  content   String   @db.VarChar(255)  // 服务端预渲染展示文案
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])       // 查未读：where { userId, read: false }
  @@index([userId, createdAt])  // 列表按时间倒序
}

// 关注关系表（独立轻量表，沿 Notification 取向：仅用标量外键，不建 @relation）
// 设计取舍：避免 User 反向数组与级联复杂度；列表/资料查询时像
// notificationService.listForUser 那样用 prisma.user.findMany({where:{id:{in: ids}}}) 补 user 信息。
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      // 关注者
  followingId Int      // 被关注者
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId]) // 同一人不能重复关注同一人（幂等基础）
  @@index([followingId])              // 查粉丝列表
}

// 举报记录表（内容审核 & 举报系统）
model Report {
  id          Int       @id @default(autoincrement())
  reporterId  Int                          // 举报人 userId
  targetType  String    @db.VarChar(10)    // 'post' | 'comment'
  targetId    Int                          // 目标帖子或评论 ID
  reason      String    @db.VarChar(20)    // 举报理由枚举值
  description String?   @db.VarChar(200)   // 补充说明（other 时必填）
  status      String    @default("pending") @db.VarChar(20) // pending/resolved/dismissed
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@unique([reporterId, targetType, targetId]) // 同一用户对同一内容仅能举报一次（幂等）
  @@index([targetType, targetId])               // 按内容查举报记录
  @@index([status, createdAt])                  // 审核队列按状态+时间排序
}

// 通知偏好开关表（用户可控的通知类别开关，默认全开）
model NotificationPreference {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  comment   Boolean  @default(true)
  up        Boolean  @default(true)
  bookmark  Boolean  @default(true)
  follow    Boolean  @default(true)
  system    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// 拉黑关系表（轻量表，仅标量外键，不建 @relation）
model Blocklist {
  id        Int      @id @default(autoincrement())
  userId    Int      // 谁拉黑的
  blockedId Int      // 被拉黑的人
  createdAt DateTime @default(now())

  @@unique([userId, blockedId])
  @@index([userId])
}

// 隐私设置表（用户可控的可见性与互动开关，默认全公开）
model PrivacySettings {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postVisibility String   @default("public") @db.VarChar(20) // public | followers | private
  allowFollow    Boolean  @default(true)
  allowMessage   Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

// 辩论投票记录表（用户对辩论帖子的 A/B 投票，幂等）
model DebateVote {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  choice    String   @db.VarChar(1) // 'A' | 'B'
  createdAt DateTime @default(now())

  @@unique([userId, postId]) // 同一用户对同一辩论帖只能投一次
}
