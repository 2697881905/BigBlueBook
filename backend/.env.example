# 后端环境变量模板
# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore 忽略，不会提交到仓库
PORT=3000

# 数据库（本机 MySQL 示例）
DATABASE_URL=mysql://bigbluebook:your_db_password@localhost:3306/bigbluebook

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# 腾讯云 COS（图片直传，必填后图片上传才可用）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_CDN_BASE=

# OSS（已弃用，保留兼容占位）
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_ENDPOINT=
CDN_BASE=

# 华为账号登录（Account Kit / 获取 UnionID）
# 在 AGC 控制台 -> 我的项目 -> 应用 -> 应用信息 中获取
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
HUAWEI_REDIRECT_URI=

# 内容审核 & 举报系统
# 审核员 userId（逗号分隔），adminAuth 中间件校验 req.userId 是否在此列表
ADMIN_USER_IDS=1
# 举报自动下架阈值（被举报达此次数自动 status=0 进入待审核队列）
REPORT_THRESHOLD=3
